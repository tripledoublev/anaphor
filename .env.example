# Default provider: OpenRouter (get a key at https://openrouter.ai)
OPENROUTER_API_KEY=your_api_key_here

# Optional: use direct GLM/Z.ai instead of OpenRouter.
# Reads ~/.config/v100/config.toml providers.glm.auth.key if no key env is set.
# ANAPHOR_PROVIDER=glm
# ANAPHOR_GLM_MODEL=glm-5.1

# Optional: use another OpenAI-compatible endpoint.
# ANAPHOR_PROVIDER=custom
# ANAPHOR_BASE_URL=https://api.example.com/v1
# ANAPHOR_API_KEY=your_api_key_here
# ANAPHOR_MODEL=provider-model-id

# Brave Search API key (get one at https://api.search.brave.com)
BRAVE_API_KEY=your_api_key_here

# Optional: override the default model
# Defaults to openai/gpt-4o-mini if not set
# ANAPHOR_MODEL=google/gemini-flash-1.5

# Optional: total context character budget
# ANAPHOR_MAX_CHARS=30000
